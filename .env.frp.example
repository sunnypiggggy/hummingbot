# Copy this file to .env.frp and fill in your frp server values.
# Do not commit .env.frp.

FRP_SERVER_ADDR=your.frps.server
FRP_SERVER_PORT=7000
FRP_AUTH_TOKEN=

# The public remote port on frps that forwards to local MCP SSE.
FRP_MCP_REMOTE_PORT=18000

# Local service inside Docker network.
FRP_MCP_LOCAL_ADDR=mcp-sse
FRP_MCP_LOCAL_PORT=18000
